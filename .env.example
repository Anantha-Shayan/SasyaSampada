# Frontend
REACT_APP_API_URL=http://localhost:8000

# Backend
BACKEND_PORT=8000
OPENWEATHER_API_KEY=your_openweather_api_key_here
MANDI_PRICE_KEY=your_mandi_price_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=900

# Optional ML / data sources
KAGGLE_API_TOKEN=your_kaggle_api_token_here

# PDF parsing (Phase 4) — optional OCR for scanned pages
OCR_ENABLED=false
PDF_MIN_TEXT_CHARS=30
PDF_HEADER_FRACTION=0.12
PDF_FOOTER_FRACTION=0.12

# Chunking (Phase 6)
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Embeddings (Phase 8)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DEVICE=cpu
EMBEDDING_NORMALIZE=true

# Qdrant (Phase 9)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=agri_knowledge
QDRANT_UPSERT_BATCH_SIZE=64

# Retrieval (Phase 10)
RETRIEVAL_TOP_K=10
RETRIEVAL_SCORE_THRESHOLD=0.0

# Prompting / RAG
PROMPT_CONFIG_PATH=
RAG_CONTEXT_MAX_CHARS=6000
RAG_CONTEXT_CHUNK_MAX_CHARS=1200
