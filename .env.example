# Frontend
REACT_APP_API_URL=http://localhost:8000

# Backend
BACKEND_PORT=8000
OPENWEATHER_API_KEY=your_openweather_api_key_here
MANDI_PRICE_KEY=your_mandi_price_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional ML / data sources
KAGGLE_API_TOKEN=your_kaggle_api_token_here

# PDF parsing (Phase 4) — optional OCR for scanned pages
OCR_ENABLED=false
PDF_MIN_TEXT_CHARS=30
PDF_HEADER_FRACTION=0.12
PDF_FOOTER_FRACTION=0.12

# Chunking (Phase 6)
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
